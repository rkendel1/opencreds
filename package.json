{
  "name": "oomol-connect",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-generated.ts",
    "dev": "node scripts/dev-local.ts",
    "dev:api": "node scripts/ensure-generated.ts && node src/server/index.ts",
    "build": "npm run typecheck",
    "build:web": "npm run build --workspace web",
    "dev:cloudflare": "npm run generate:catalog && npm run build:web && node scripts/copy-catalog-assets.ts && wrangler dev --config wrangler.local.jsonc",
    "deploy:cloudflare": "npm run generate:catalog && npm run build:web && node scripts/copy-catalog-assets.ts && wrangler deploy --config wrangler.local.jsonc",
    "start": "node scripts/ensure-generated.ts && node src/server/index.ts",
    "test": "vitest run",
    "typecheck": "npm run generate:registry && node scripts/typecheck.ts src scripts-all examples",
    "generate:registry": "node scripts/generate-provider-registry.ts",
    "generate:catalog": "npm run generate:registry && node scripts/generate-catalog.ts",
    "runtime:data": "node scripts/runtime-data.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "fix": "npm run lint:fix && npm run format:fix",
    "fix-check": "npm run fix && npm run typecheck"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.11.7",
    "ali-oss": "^6.23.0",
    "hono": "^4.12.27",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-extension-gfm": "^3.0.0",
    "minisearch": "^7.2.0",
    "pino": "^10.3.1",
    "rss-parser": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hyrious/configs": "^0.1.6",
    "@types/ali-oss": "^6.23.3",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260630.1": true
  }
}
